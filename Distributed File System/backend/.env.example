# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Shared secret that all storage nodes must include when registering
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
NODE_SECRET=your_node_secret_here

# Public URL of this backend (used by nodes to register)
BACKEND_URL=http://localhost:5000

# Optional: override default port 5000
# PORT=5000

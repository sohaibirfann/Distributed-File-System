{
  "name": "dfs-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "DFS desktop app — Electron shell + embedded storage node",
  "author": "Sohaib Irfan",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "npm --prefix ../frontend run build && electron-builder --dir",
    "dist": "npm --prefix ../frontend run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dfs.app",
    "productName": "DFS",
    "directories": { "output": "release" },
    "files": ["main.js", "preload.js", "storageNode.js", "icon.png"],
    "extraResources": [{ "from": "../frontend/dist", "to": "ui" }],
    "win": { "target": "nsis", "icon": "icon.png" },
    "linux": { "target": "AppImage", "icon": "icon.png", "category": "Network" },
    "mac": { "target": "dmg", "icon": "icon.png" }
  }
}
